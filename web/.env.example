DATABASE_URL=your-database-url

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_OUT_URL=/sign-in

NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

SUPABASE_STORAGE_BUCKET=chat-uploads
# Signed URL lifetime for downloads (seconds), default 7 days
# SUPABASE_STORAGE_SIGNED_URL_TTL_SEC=604800
# Optional upload limits (MB)
# UPLOAD_IMAGE_MAX_MB=8
# UPLOAD_DOCUMENT_MAX_MB=20
# Max bytes when fetching a doc from signed URL before upload to OpenAI (default 25 MB)
# DOCUMENT_FETCH_MAX_BYTES=26214400
# Max OpenAI file parts per chat request (re-sends docs from earlier user messages on follow-ups)
CHAT_MAX_OPENAI_FILES=1

OPENAI_API_KEY=sk-...
# Optional; default gpt-4o-mini (vision + file inputs for chat attachments)
# OPENAI_CHAT_MODEL=gpt-4o-mini
# Optional system instruction
# OPENAI_SYSTEM_PROMPT=You are a helpful assistant.
